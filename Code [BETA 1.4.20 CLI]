def ensure_system_tools():
    missing = []

    for tool in ["aria2c", "ffmpeg", "7z"]:
        if shutil.which(tool) is None:
            missing.append(tool)

    if missing:
        run_bootstrap_command(["apt-get", "update", "-qq"], "Updating apt package index")
        run_bootstrap_command(["apt-get", "install", "-y", "aria2", "ffmpeg", "p7zip-full"], "Installing system packages")


def ensure_python_package(import_name, package_name=None):
    package_name = package_name or import_name

    try:
        __import__(import_name)
    except ModuleNotFoundError:
        run_bootstrap_command([sys.executable, "-m", "pip", "install", "-q", package_name], "Installing Python package: " + package_name)


